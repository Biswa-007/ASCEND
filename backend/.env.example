# Ascend Backend Environment Variables
# Copy this file to .env and fill in values before running the server.

# ------- Database -------
# Use asyncpg driver: postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://ascend:password@localhost:5432/ascend_db

# ------- JWT Auth -------
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ------- CORS (comma-separated list of allowed origins) -------
# ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
