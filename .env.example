# =============================================================================
# Ascend — Root Environment Variables
# Copy relevant sections to backend/.env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=ascend
POSTGRES_PASSWORD=password
POSTGRES_DB=ascend_db

# --- Backend ---
DATABASE_URL=postgresql+asyncpg://ascend:password@localhost:5432/ascend_db
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
